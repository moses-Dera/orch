# ---- Orch Core Configuration ----
# Copy this file to .env and fill in your values
# Never commit .env to git

# Environment
ENV=development

# Database (PostgreSQL required for production, SQLite for dev)
DATABASE_URL="postgresql://user:password@localhost:5432/orch"

# LLM — at least one key required
GEMINI_API_KEY=your-google-ai-key-here
# OPENAI_API_KEY=your-openai-key-here

# Default models (litellm format)
DEFAULT_MODEL=gemini/gemini-1.5-pro
ROUTER_MODEL=gemini/gemini-1.5-flash

# Redis (optional — caching degrades gracefully without it)
REDIS_URL=redis://localhost:6379

# Encryption — REQUIRED in production
LOCAL_ENCRYPTION_KEY=generate-a-long-random-string-here

# AWS KMS (optional — use instead of LOCAL_ENCRYPTION_KEY in production)
# KMS_KEY_ID=arn:aws:kms:us-east-1:123456789:key/your-key-id
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# GitHub App (optional — needed for GitHub App integration)
# GITHUB_APP_ID=your-app-id
# GITHUB_APP_PRIVATE_KEY=base64-encoded-pem-key
# GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Rate limits (requests per minute per tier)
RATE_LIMIT_FREE=10
RATE_LIMIT_PRO=60
RATE_LIMIT_BUSINESS=200
RATE_LIMIT_ENTERPRISE=1000

# CORS — add your dashboard URL
CORS_ORIGINS=["http://localhost:3000"]

# Orch server-to-server API key (used by dashboard proxy)
ORCH_API_KEY=generate-with-seed.py
